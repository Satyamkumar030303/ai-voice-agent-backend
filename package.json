{
  "name": "ai-voice-agent-backend",
  "version": "1.0.0",
  "description": "Backend for AI Voice Agent using LiveKit, Twilio and Gemini",
  "main": "src/app.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start:backend": "node server.js",
    "start:agent": "node src/services/agent.mjs dev",
    "start:backend:log": "node server.js 2>&1",
    "start:agent:log": "node src/services/agent.mjs dev 2>&1",
    "start:debug": "concurrently --prefix \"[{name}]\" --names \"backend,agent\" --timestamp-format \"HH:mm:ss\" --prefix-colors \"cyan,yellow\" \"npm run start:backend:log\" \"npm run start:agent:log\"",
    "start": "concurrently \"npm run start:backend\" \"npm run start:agent\"",
    "test": "echo \"No tests specified\""
  },
  "keywords": [
    "livekit",
    "twilio",
    "ai-agent",
    "gemini",
    "voice-agent"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@livekit/agents": "^1.0.50",
    "@livekit/agents-plugin-deepgram": "^1.0.50",
    "@livekit/agents-plugin-elevenlabs": "^1.0.50",
    "@livekit/agents-plugin-google": "^1.0.50",
    "@livekit/agents-plugin-openai": "^1.0.50",
    "@livekit/rtc-node": "^0.13.24",
    "@livekit/rtc-node-win32-x64-msvc": "^0.13.24",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "langchain": "^1.2.30",
    "livekit-client": "^2.17.2",
    "livekit-server-sdk": "^2.15.0",
    "mongodb": "^7.1.0",
    "mongoose": "^9.3.0",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.2",
    "pdf-parse": "^1.1.1",
    "stripe": "^20.4.1",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.14"
  }
}
